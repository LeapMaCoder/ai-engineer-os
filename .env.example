# LeapMa 环境变量示例
# 复制为仓库根目录 `.env` 或 `apps/leapma_web/.env`。切勿提交真实密钥。

# --- 应用 ---
APP_NAME=LeapMa
FLASK_SECRET_KEY=leapma-dev-only-change-me

# --- 数据库（ADR-0002：MySQL Primary Store）---
# 推荐（规范路径）：
# DATABASE_URL=mysql://USER:PASSWORD@127.0.0.1:3306/leapma
#
# 本地零配置跑通可用 SQLite（仅开发；非 ADR 主路径）：
# 省略 DATABASE_URL 时默认 apps/leapma_web/data/leapma.db

# --- LLM Provider（AQ-002：可替换；默认 mock）---
LEAPMA_LLM_PROVIDER=mock
# LEAPMA_LLM_PROVIDER=openai_compatible
# LEAPMA_LLM_BASE_URL=https://api.openai.com/v1
# LEAPMA_LLM_API_KEY=
# LEAPMA_LLM_MODEL=gpt-4o-mini
