# LeapMa 环境变量示例
# 复制为仓库根目录 `.env` 或 `apps/leapma_web/.env`。切勿提交真实密钥。

APP_NAME=LeapMa
FLASK_SECRET_KEY=dev-change-me

# MySQL Primary Store（ADR-0002）— 将 USER/PASSWORD 换成你的本地账号
# DATABASE_URL=mysql://USER:PASSWORD@127.0.0.1:3306/leapma

# 若未设置 DATABASE_URL，应用回退到 apps/leapma_web/data/leapma.db（SQLite，仅开发）

# 反馈：默认 mock；Python 章内练习走规则判定，不以真实 LLM 为前提
LEAPMA_LLM_PROVIDER=mock
# LEAPMA_LLM_PROVIDER=openai_compatible
# LEAPMA_LLM_BASE_URL=https://api.openai.com/v1
# LEAPMA_LLM_API_KEY=
# LEAPMA_LLM_MODEL=gpt-4o-mini
